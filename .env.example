# Public domain served by Caddy.
DOMAIN=example.com

# Frontend
NEXT_PUBLIC_SITE_URL=https://${DOMAIN}
NEXT_PUBLIC_API_URL=https://${DOMAIN}/api
API_URL=http://backend:3005/api

# Backend
PUBLIC_URL=https://${DOMAIN}
CORS_ORIGIN=https://${DOMAIN}
JWT_SECRET=replace-with-at-least-64-random-characters
REFRESH_SECRET=replace-with-at-least-64-random-characters

# Infrastructure
POSTGRES_DB=it_blog
POSTGRES_USER=it_blog
POSTGRES_PASSWORD=replace-with-a-strong-password

PGADMIN_DEFAULT_EMAIL=example@yandex.ru
PGADMIN_DEFAULT_PASSWORD=example
